# 密钥
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# 运行期数据 / PII（账号、cookie、日志、截图）
cookies/**
!cookies/.gitkeep
!cookies/chatgpt/.gitkeep
# 标准 token（access_token / sso 等敏感凭据，绝不进库）
tokens/**
!tokens/.gitkeep
emails.txt
emails_*.txt
proxies.txt
outlook_accounts/
*_accounts/
_outlook_pool/*.json
tri_register_logs/*
!tri_register_logs/.gitkeep
screenshots/*
!screenshots/.gitkeep
screenshots_outlook/*
!screenshots_outlook/.gitkeep
screenshots_github/*
!screenshots_github/.gitkeep
# GitHub 验证求解的临时调试脚本（不进库）
_gh_*.py
# 录屏工具与产物（本地调试用，不进库）
record_and_run.py
record_cmd.py
stop_recording.py
recordings/
*.log
claude_node_usage.txt

# Gmail Android release/offline binary payloads
gmail_android/offline/bluestacks/*
!gmail_android/offline/bluestacks/.gitkeep
gmail_android/dist/
screenshots_vision/
